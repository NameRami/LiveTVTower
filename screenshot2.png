        <div class="country-card-count">2 ch</div>
      </div>
    </div><div class="country-card " onclick="selectCountry(&#39;VN&#39;)">
      <div class="country-card-flag">🇵🇭</div>
      <div class="country-card-body">
        <div class="country-card-name">Vietnam</div>
        <div class="country-card-count">64 ch</div>
      </div>
    </div><div class="country-card " onclick="selectCountry(&#39;WS&#39;)">
      <div class="country-card-flag">🇶🇲</div>
      <div class="country-card-body">
        <div class="country-card-name">WS</div>
        <div class="country-card-count">2 ch</div>
      </div>
    </div><div class="country-card " onclick="selectCountry(&#39;XK&#39;)">
      <div class="country-card-flag">🇷🇪</div>
      <div class="country-card-body">
        <div class="country-card-name">XK</div>
        <div class="country-card-count">12 ch</div>
      </div>
    </div><div class="country-card " onclick="selectCountry(&#39;YE&#39;)">
      <div class="country-card-flag">🇸🇤</div>
      <div class="country-card-body">
        <div class="country-card-name">Yemen</div>
        <div class="country-card-count">6 ch</div>
      </div>
    </div><div class="country-card " onclick="selectCountry(&#39;ZW&#39;)">
      <div class="country-card-flag">🇹🇶</div>
      <div class="country-card-body">
        <div class="country-card-name">Zimbabwe</div>
        <div class="country-card-count">1 ch</div>
      </div>
    </div></div>
    <div class="country-modal-foot">
      <div class="country-active-pill" id="country-active-pill" style="display:none">
        <span id="country-active-label"></span>
        <span class="cpill-clear" onclick="clearCountryFilter()">✕ Clear</span>
      </div>
      <div style="flex:1"></div>
      <button class="btn-cancel" onclick="closeCountryOverlay()">Close</button>
    </div>
  </div>
</div>

<!-- M3U MODAL -->
<div class="modal-bg" id="m3u-modal">
  <div class="modal">
    <h3>Add custom M3U playlist or stream URL</h3>
    <p>Paste a direct .m3u8 stream URL to add a single channel, or an M3U playlist URL to import multiple channels. They'll appear at the top of the picker.</p>
    <input type="text" id="m3u-name" placeholder="Channel name (for single URL)">
    <input type="text" id="m3u-url" placeholder="https://example.com/stream.m3u8 or playlist.m3u">
    <div class="modal-foot">
      <button class="btn-cancel" onclick="closeM3U()">Cancel</button>
      <button class="btn-ok" onclick="addM3U()">Add →</button>
    </div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════
let layout = 2;
let slots = [];          // Array<{chId,name,flag,logo}|null>
let activeSlot = null;   // index being picked into
let focusedSlot = null;  // index with sound on
let masterMuted = true;

let allChannels = [];    // iptv-org enriched
let customChannels = []; // user-added M3U
let searchQ = '';
let activeCat = '';
let activeCountry = ''; // ISO code of selected country filter

const hlsInst = {};      // key='slot-N' → Hls instance

// iptv-org logo API base
const LOGO_API = 'https://iptv-org.github.io/api/';

// Pinned favourites — always shown first in picker
const FAVS = [
  {id:'SkyNews.gb',        name:'Sky News',       country:'GB', flag:'🇬🇧', logo:'https://upload.wikimedia.org/wikipedia/en/thumb/8/81/Sky_News_International_logo_2016.svg/200px-Sky_News_International_logo_2016.svg.png', urls:['https://linear901-oo-hls0-prd-gtm.delivery.skycdp.com/17501/sde-fast-skynews/master.m3u8']},
  {id:'Euronews.int',      name:'Euronews',       country:'EU', flag:'🇪🇺', logo:'https://upload.wikimedia.org/wikipedia/commons/thumb/1/1e/Euronews_2022_logo.svg/200px-Euronews_2022_logo.svg.png', urls:['https://dash4.antik.sk/live/test_euronews/playlist.m3u8']},
  {id:'DWNews.de',         name:'DW News',        country:'DE', flag:'🇩🇪', logo:'https://upload.wikimedia.org/wikipedia/commons/thumb/4/40/DW_logo_2012.svg/200px-DW_logo_2012.svg.png', urls:['https://dwamdstream103.akamaized.net/hls/live/2015526/dwstream103/master.m3u8']},
  {id:'France24.fr',       name:'France 24',      country:'FR', flag:'🇫🇷', logo:'https://upload.wikimedia.org/wikipedia/commons/thumb/a/aa/France_24_logo.svg/200px-France_24_logo.svg.png', urls:['https://amg00106-france24-france24-samsunguk-qvpp8.amagi.tv/playlist/amg00106-france24-france24-samsunguk/playlist.m3u8']},
  {id:'AlJazeeraEnglish.qa',name:'Al Jazeera',   country:'QA', flag:'🇶🇦', logo:'https://upload.wikimedia.org/wikipedia/en/thumb/f/f2/Al_Jazeera_English_Logo.svg/200px-Al_Jazeera_English_Logo.svg.png', urls:['https://live-hls-apps-aje-fa.getaj.net/AJE/index.m3u8','https://live-hls-web-aje.getaj.net/AJE/index.m3u8']},
  {id:'CNN.us',            name:'CNN',            country:'US', flag:'🇺🇸', logo:'https://upload.wikimedia.org/wikipedia/commons/thumb/b/b1/CNN.svg/200px-CNN.svg.png', urls:['https://cnnlive.nuvid.tv/cnn/index.m3u8']},
  {id:'BBCWS.gb',          name:'BBC World News', country:'GB', flag:'🇬🇧', logo:'https://upload.wikimedia.org/wikipedia/commons/thumb/6/6e/BBC_World_News_2022.svg/200px-BBC_World_News_2022.svg.png', urls:['https://vs-cmaf-push-ww.live.fastly.net/x=4/i=urn:bbc:pips:service:bbc_world_service_tv/t=3840/v=pv14/b=5070016/latest.mpd']},
];

// Country code → emoji flag
function countryFlag(code){
  if(!code||code.length!==2) return '📺';
  return [...code.toUpperCase()].map(c=>String.fromCodePoint(0x1F1E0-65+c.charCodeAt(0))).join('');
}

// ═══════════════════════════════════════════════════
// INIT — fetch iptv-org catalogue
// ═══════════════════════════════════════════════════
async function init(){
  try{
    const [chRes, stRes] = await Promise.all([
      fetch('https://iptv-org.github.io/api/channels.json'),
      fetch('https://iptv-org.github.io/api/streams.json'),
    ]);
    const channels = await chRes.json();
    const streams  = await stRes.json();

    // Build stream map
    const sm = {};
    streams.forEach(s => {
      if(!sm[s.channel]) sm[s.channel] = [];
      sm[s.channel].push(s.url);
    });

    // Keep only channels with streams, attach URLs + computed flag
    allChannels = channels
      .filter(ch => sm[ch.id] && !ch.is_nsfw)
      .map(ch => ({
        ...ch,
        urls: sm[ch.id],
        flag: countryFlag(ch.country),
      }));

    document.getElementById('ch-count').innerHTML =
      `<span class="live-dot"></span>${allChannels.length.toLocaleString()} channels`;

    buildCats();
    renderPicker();
    document.getElementById('load-overlay').style.display = 'none';
  } catch(e){
    document.getElementById('load-overlay').innerHTML =
      `<div style="font-size:11px;color:var(--err);padding:20px;text-align:center">Failed to load channel catalogue.<br>Check your connection and reload.</div>`;
  }
}

// ═══════════════════════════════════════════════════
// LAYOUT
// ═══════════════════════════════════════════════════
function setLayout(n, btn){
  layout = n;
  document.querySelectorAll('.lbtn').forEach(b => b.classList.remove('on'));
  if(btn) btn.classList.add('on');
  // Destroy HLS for removed slots
  for(let i = n; i < slots.length; i++) destroySlot(i);
  slots = slots.slice(0, n);
  while(slots.length < n) slots.push(null);
  if(activeSlot >= n) activeSlot = null;
  if(focusedSlot >= n) focusedSlot = null;
  buildGrid();
  // Save layout pref
  try{ localStorage.setItem('sw_layout', n); }catch{}
}

function buildGrid(){
  const wrap = document.getElementById('screens');
  wrap.className = 'screens s' + layout;

  // Save existing video elements
  const savedVids = {};
  for(let i = 0; i < layout; i++){
    const v = document.getElementById('slot-vid-'+i);
    if(v) savedVids[i] = v;
  }
  wrap.innerHTML = '';

  slots.forEach((slot, i) => {
    const el = document.createElement('div');
    el.className = 'slot' +
      (slot ? ' live' : '') +
      (i === activeSlot ? ' active-pick' : '') +
      (i === focusedSlot ? ' focused' : '');
    el.id = 'slot-' + i;

    el.innerHTML = `
      <div class="slot-hdr" id="slot-hdr-${i}">
        ${slot?.logo ? `<img class="slot-logo" src="${slot.logo}" onerror="this.style.display='none'" loading="lazy"/>` : ''}
        <span class="slot-name ${slot?'live':''}" id="slot-name-${i}">${slot ? slot.flag+' '+slot.name : 'Screen '+(i+1)}</span>
        <span class="slot-sound">🔊</span>
        <span class="slot-st" id="slot-st-${i}"></span>
        ${i === activeSlot ? `<span class="active-badge">← pick</span>` : ''}
        ${slot ? `<button class="slot-fs" title="Fullscreen" onclick="event.stopPropagation();fsSlot(${i})">⛶</button>` : ''}
        ${slot ? `<button class="slot-close" title="Remove" onclick="event.stopPropagation();clearSlot(${i})">✕</button>` : ''}
      </div>
      <div class="slot-vw" id="slot-vw-${i}">
        <div class="slot-ph" id="slot-ph-${i}" style="${slot?'display:none':''}">
          <div class="slot-ph-icon">${i === activeSlot ? '👆' : '📺'}</div>
          <div class="slot-ph-txt">${i === activeSlot ? 'Pick a channel →' : 'Click to select'}</div>
          ${i === activeSlot ? '' : '<div class="slot-ph-hint">or double-click for fullscreen</div>'}
        </div>
      </div>`;

    // Re-attach or create video
    const vw = el.querySelector('.slot-vw');
    if(savedVids[i]){
      vw.appendChild(savedVids[i]);
    } else {
      const vid = document.createElement('video');
      vid.id = 'slot-vid-' + i;
      vid.autoplay = true; vid.muted = true; vid.playsInline = true; vid.controls = true;
      vid.style.cssText = 'display:none;width:100%;height:100%';
      vw.appendChild(vid);
    }

    el.addEventListener('click', () => selectSlot(i));
    el.querySelector('.slot-vw').addEventListener('dblclick', e => {
      e.stopPropagation(); fsSlot(i);
    });

    wrap.appendChild(el);
  });

  syncMute();
}

function selectSlot(i){
  activeSlot = i;
  if(slots[i]) focusedSlot = i;
  refreshSlotClasses();
  syncMute();
}

function refreshSlotClasses(){
  slots.forEach((slot, i) => {
    const el = document.getElementById('slot-' + i);
    if(!el) return;
    el.className = 'slot' +
      (slot ? ' live' : '') +
      (i === activeSlot ? ' active-pick' : '') +
      (i === focusedSlot ? ' focused' : '');

    // Update header active badge
    const hdr = document.getElementById('slot-hdr-' + i);
    hdr?.querySelector('.active-badge')?.remove();
    if(i === activeSlot && hdr){
      const b = document.createElement('span');
      b.className = 'active-badge';
      b.textContent = '← pick';
      hdr.insertBefore(b, hdr.querySelector('.slot-fs') || hdr.querySelector('.slot-close') || null);
    }

    // Placeholder text
    const ph = document.getElementById('slot-ph-' + i);
    if(ph && !slot){
      ph.style.display = 'flex';
      ph.querySelector('.slot-ph-icon').textContent = i === activeSlot ? '👆' : '📺';
      ph.querySelector('.slot-ph-txt').textContent  = i === activeSlot ? 'Pick a channel →' : 'Click to select';
    }
  });
}

// ═══════════════════════════════════════════════════
// ASSIGN CHANNEL TO SLOT
// ═══════════════════════════════════════════════════
function assignChannel(chId){
  if(activeSlot === null){
    activeSlot = slots.findIndex(s => !s);
    if(activeSlot === -1) activeSlot = 0;
  }

  const ch = FAVS.find(c => c.id === chId)
           || customChannels.find(c => c.id === chId)
           || allChannels.find(c => c.id === chId);
  if(!ch) return;

  const i = activeSlot;
  destroySlot(i);

  slots[i] = { chId: ch.id, name: ch.name, flag: ch.flag || countryFlag(ch.country), logo: ch.logo || null };

  // Update header
  const hdr = document.getElementById('slot-hdr-' + i);
  if(hdr){
    // Logo
    let logoEl = hdr.querySelector('.slot-logo');
    if(ch.logo){
      if(!logoEl){
        logoEl = document.createElement('img');
        logoEl.className = 'slot-logo';
        logoEl.loading = 'lazy';
        logoEl.onerror = function(){ this.style.display='none'; };
        hdr.prepend(logoEl);
      }
      logoEl.src = ch.logo;
      logoEl.style.display = '';
    } else if(logoEl) logoEl.style.display = 'none';

    // Name
    const nameEl = document.getElementById('slot-name-' + i);
    if(nameEl){ nameEl.textContent = (ch.flag || countryFlag(ch.country)) + ' ' + ch.name; nameEl.className = 'slot-name live'; }

    // Buttons
    if(!hdr.querySelector('.slot-fs')){
      const fs = document.createElement('button');
      fs.className = 'slot-fs'; fs.title = 'Fullscreen'; fs.textContent = '⛶';
      fs.onclick = e => { e.stopPropagation(); fsSlot(i); };
      hdr.appendChild(fs);
    }
    if(!hdr.querySelector('.slot-close')){
      const cl = document.createElement('button');
      cl.className = 'slot-close'; cl.title = 'Remove'; cl.textContent = '✕';
      cl.onclick = e => { e.stopPropagation(); clearSlot(i); };
      hdr.appendChild(cl);
    }
  }

  // Show video, hide placeholder
  const ph = document.getElementById('slot-ph-' + i);
  if(ph) ph.style.display = 'none';
  const vid = document.getElementById('slot-vid-' + i);
  if(vid) vid.style.display = 'block';

  // Focus sound
  focusedSlot = i;
  syncMute();

  // Load stream
  const urls = ch.urls || (ch._streams || []).map(s => s.url || s);
  loadStream(i, urls);

  // Auto-advance to next empty slot
  const next = slots.findIndex((s, j) => j > i && !s);
  activeSlot = next !== -1 ? next : null;
  refreshSlotClasses();

  // Persist session
  saveSession();
}

// ═══════════════════════════════════════════════════
// HLS LOADING
// ═══════════════════════════════════════════════════
function loadStream(slotIdx, urls){
  const key = 'slot-' + slotIdx;
  const vid = document.getElementById('slot-vid-' + slotIdx);
  const ph  = document.getElementById('slot-ph-' + slotIdx);
  const st  = document.getElementById('slot-st-' + slotIdx);
  if(!vid || !urls?.length) return;

  let idx = 0;
  function tryNext(){
    if(idx >= urls.length){
      if(st){ st.textContent = '✕ offline'; st.className = 'slot-st err'; }
      if(ph) ph.style.display = 'flex';
      vid.style.display = 'none';
      return;
    }
    const url = urls[idx++];
    if(st){ st.textContent = '…'; st.className = 'slot-st loading'; }
    if(ph) ph.style.display = 'none';
    vid.style.display = 'block';

    if(hlsInst[key]){ hlsInst[key].destroy(); delete hlsInst[key]; }

    if(Hls.isSupported()){
      const hls = new Hls({ enableWorker: false, lowLatencyMode: true });
      hlsInst[key] = hls;
      hls.loadSource(url);
      hls.attachMedia(vid);
      hls.on(Hls.Events.MANIFEST_PARSED, () => {
        vid.play().catch(() => {});
        if(st){ st.textContent = '● LIVE'; st.className = 'slot-st live'; }
        syncMute();
      });
      hls.on(Hls.Events.ERROR, (_, d) => { if(d.fatal) tryNext(); });
    } else if(vid.canPlayType('application/vnd.apple.mpegurl')){
      vid.src = url;
      vid.oncanplay = () => { vid.play().catch(()=>{}); if(st){ st.textContent='● LIVE'; st.className='slot-st live'; } };
      vid.onerror = tryNext;
    } else {
      if(st){ st.textContent = '✕ N/A'; st.className = 'slot-st err'; }
    }
  }
  tryNext();
}

function destroySlot(i){
  const key = 'slot-' + i;
  if(hlsInst[key]){ hlsInst[key].destroy(); delete hlsInst[key]; }
  const vid = document.getElementById('slot-vid-' + i);
  if(vid){ vid.src = ''; vid.style.display = 'none'; }
}

function clearSlot(i){
  destroySlot(i);
  slots[i] = null;
  if(activeSlot === i) activeSlot = null;
  if(focusedSlot === i) focusedSlot = null;

  const slotEl = document.getElementById('slot-' + i);
  if(slotEl) slotEl.className = 'slot';
  const nameEl = document.getElementById('slot-name-' + i);
  if(nameEl){ nameEl.textContent = 'Screen '+(i+1); nameEl.className = 'slot-name'; }
  const stEl = document.getElementById('slot-st-' + i);
  if(stEl){ stEl.textContent = ''; stEl.className = 'slot-st'; }
  const hdr = document.getElementById('slot-hdr-' + i);
  hdr?.querySelector('.slot-close')?.remove();
  hdr?.querySelector('.slot-fs')?.remove();
  hdr?.querySelector('.active-badge')?.remove();
  const logoEl = hdr?.querySelector('.slot-logo');
  if(logoEl) logoEl.style.display = 'none';
  const ph = document.getElementById('slot-ph-' + i);
  if(ph){ ph.style.display='flex'; ph.querySelector('.slot-ph-icon').textContent='📺'; ph.querySelector('.slot-ph-txt').textContent='Click to select'; }
  syncMute();
  saveSession();
}

function clearAll(){
  for(let i = 0; i < layout; i++) destroySlot(i);
  slots = slots.map(() => null);
  activeSlot = null; focusedSlot = null;
  buildGrid();
  saveSession();
}

function fsSlot(i){
  const vid = document.getElementById('slot-vid-' + i);
  if(vid?.requestFullscreen) vid.requestFullscreen();
}

// ═══════════════════════════════════════════════════
// MUTE
// ═══════════════════════════════════════════════════
function syncMute(){
  slots.forEach((_, i) => {
    const vid = document.getElementById('slot-vid-' + i);
    if(!vid) return;
    vid.muted = masterMuted || focusedSlot !== i;
  });
}

function toggleMaster(){
  masterMuted = !masterMuted;
  const btn = document.getElementById('mute-btn');
  btn.textContent = masterMuted ? '🔇' : '🔊';
  btn.classList.toggle('on', !masterMuted);
  syncMute();
}

// ═══════════════════════════════════════════════════
// PICKER
// ═══════════════════════════════════════════════════
function buildCats(){
  const cats = [...new Set(allChannels.flatMap(ch => ch.categories || []))].filter(Boolean).sort();
  const wrap = document.getElementById('cats');
  wrap.innerHTML = ['all', ...cats].map(c =>
    `<button class="cat-btn ${c==='all'?'on':''}" onclick="setCat('${c}',this)">${c==='all'?'All':c}</button>`
  ).join('');
}

function setCat(c, btn){
  activeCat = c === 'all' ? '' : c;
  document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('on'));
  btn?.classList.add('on');
  renderPicker();
}

function onSearch(v){
  searchQ = v.toLowerCase();
  renderPicker();
}

// ── COUNTRY OVERLAY ──
const COUNTRY_NAMES = {
  AF:'Afghanistan',AL:'Albania',DZ:'Algeria',AD:'Andorra',AO:'Angola',AR:'Argentina',AM:'Armenia',AU:'Australia',AT:'Austria',AZ:'Azerbaijan',BS:'Bahamas',BH:'Bahrain',BD:'Bangladesh',BY:'Belarus',BE:'Belgium',BZ:'Belize',BJ:'Benin',BO:'Bolivia',BA:'Bosnia',BW:'Botswana',BR:'Brazil',BN:'Brunei',BG:'Bulgaria',BF:'Burkina Faso',BI:'Burundi',KH:'Cambodia',CM:'Cameroon',CA:'Canada',CV:'Cape Verde',CF:'Central African Rep.',TD:'Chad',CL:'Chile',CN:'China',CO:'Colombia',CD:'Congo (DRC)',CG:'Congo',CR:'Costa Rica',HR:'Croatia',CU:'Cuba',CY:'Cyprus',CZ:'Czechia',DK:'Denmark',DJ:'Djibouti',DO:'Dominican Republic',EC:'Ecuador',EG:'Egypt',SV:'El Salvador',GQ:'Equatorial Guinea',ER:'Eritrea',EE:'Estonia',ET:'Ethiopia',FJ:'Fiji',FI:'Finland',FR:'France',GA:'Gabon',GM:'Gambia',GE:'Georgia',DE:'Germany',GH:'Ghana',GR:'Greece',GT:'Guatemala',GN:'Guinea',GW:'Guinea-Bissau',HT:'Haiti',HN:'Honduras',HK:'Hong Kong',HU:'Hungary',IN:'India',ID:'Indonesia',IR:'Iran',IQ:'Iraq',IE:'Ireland',IL:'Israel',IT:'Italy',CI:"Côte d'Ivoire",JM:'Jamaica',JP:'Japan',JO:'Jordan',KZ:'Kazakhstan',KE:'Kenya',KW:'Kuwait',KG:'Kyrgyzstan',LA:'Laos',LV:'Latvia',LB:'Lebanon',LS:'Lesotho',LR:'Liberia',LY:'Libya',LT:'Lithuania',LU:'Luxembourg',MK:'North Macedonia',MG:'Madagascar',MW:'Malawi',MY:'Malaysia',MV:'Maldives',ML:'Mali',MT:'Malta',MR:'Mauritania',MX:'Mexico',MD:'Moldova',MN:'Mongolia',ME:'Montenegro',MA:'Morocco',MZ:'Mozambique',MM:'Myanmar',NA:'Namibia',NP:'Nepal',NL:'Netherlands',NZ:'New Zealand',NI:'Nicaragua',NE:'Niger',NG:'Nigeria',KP:'North Korea',NO:'Norway',OM:'Oman',PK:'Pakistan',PS:'Palestine',PA:'Panama',PG:'Papua New Guinea',PY:'Paraguay',PE:'Peru',PH:'Philippines',PL:'Poland',PT:'Portugal',PR:'Puerto Rico',QA:'Qatar',RO:'Romania',RU:'Russia',RW:'Rwanda',SA:'Saudi Arabia',SN:'Senegal',RS:'Serbia',SL:'Sierra Leone',SO:'Somalia',ZA:'South Africa',SS:'South Sudan',ES:'Spain',LK:'Sri Lanka',SD:'Sudan',SE:'Sweden',CH:'Switzerland',SY:'Syria',TW:'Taiwan',TJ:'Tajikistan',TZ:'Tanzania',TH:'Thailand',TL:'Timor-Leste',TG:'Togo',TT:'Trinidad and Tobago',TN:'Tunisia',TR:'Turkey',TM:'Turkmenistan',UG:'Uganda',UA:'Ukraine',AE:'United Arab Emirates',GB:'United Kingdom',US:'United States',UY:'Uruguay',UZ:'Uzbekistan',VE:'Venezuela',VN:'Vietnam',YE:'Yemen',ZM:'Zambia',ZW:'Zimbabwe',
};

function openCountryOverlay(){
  document.getElementById('country-overlay').classList.add('open');
  document.getElementById('country-search-input').value = '';
  renderCountryGrid('');
  document.getElementById('country-search-input').focus();
}

function closeCountryOverlay(){
  document.getElementById('country-overlay').classList.remove('open');
}

function renderCountryGrid(q = ''){
  const sq = q.toLowerCase();
  // Build country map from loaded channels
  const counts = {};
  allChannels.forEach(ch => {
    if(!ch.country) return;
    counts[ch.country] = (counts[ch.country] || 0) + 1;
  });

  const entries = Object.entries(counts)
    .map(([cc, n]) => ({ cc, n, name: COUNTRY_NAMES[cc] || cc, flag: countryFlag(cc) }))
    .filter(e => !sq || e.name.toLowerCase().includes(sq) || e.cc.toLowerCase().includes(sq))
    .sort((a, b) => a.name.localeCompare(b.name));

  const grid = document.getElementById('country-grid');
  if(!entries.length){
    grid.innerHTML = '<div style="grid-column:1/-1;padding:30px;text-align:center;color:var(--muted);font-size:11px">No countries found</div>';
    return;
  }

  grid.innerHTML = entries.map(e =>
    `<div class="country-card ${activeCountry === e.cc ? 'active' : ''}" onclick="selectCountry('${e.cc}')">
      <div class="country-card-flag">${e.flag}</div>
      <div class="country-card-body">
        <div class="country-card-name">${e.name}</div>
        <div class="country-card-count">${e.n} ch</div>
      </div>
    </div>`
  ).join('');
}

function selectCountry(cc){
  activeCountry = cc;
  // Update country button in topbar to show active state
  const btn = document.getElementById('country-btn');
  if(btn){ btn.textContent = `${countryFlag(cc)} ${COUNTRY_NAMES[cc]||cc}`; btn.style.color='var(--accent)'; btn.style.borderColor='var(--accent)'; }
  // Show active pill in footer
  const pill = document.getElementById('country-active-pill');
  const label = document.getElementById('country-active-label');
  if(pill) pill.style.display = 'flex';
  if(label) label.textContent = `${countryFlag(cc)} ${COUNTRY_NAMES[cc]||cc}`;
  // Refresh grid to highlight selection
  renderCountryGrid(document.getElementById('country-search-input').value);
  // Apply filter to picker and close
  renderPicker();
  setTimeout(closeCountryOverlay, 180);
}

function clearCountryFilter(){
  activeCountry = '';
  const btn = document.getElementById('country-btn');
  if(btn){ btn.textContent = '🌍 Country'; btn.style.color=''; btn.style.borderColor=''; }
  const pill = document.getElementById('country-active-pill');
  if(pill) pill.style.display = 'none';
  renderPicker();
  renderCountryGrid(document.getElementById('country-search-input')?.value || '');
}

function renderPicker(){
  const list = document.getElementById('picker-list');

  const favHtml = FAVS
    .filter(ch => {
      if(searchQ && !ch.name.toLowerCase().includes(searchQ)) return false;
      if(activeCountry && ch.country !== activeCountry) return false;
      return true;
    })
    .map(ch => pickItem(ch, true))
    .join('');

  const customHtml = customChannels
    .filter(ch => {
      if(searchQ && !ch.name.toLowerCase().includes(searchQ)) return false;
      if(activeCountry && ch.country !== activeCountry) return false;
      return true;
    })
    .map(ch => pickItem(ch, false, true))
    .join('');

  const filtered = allChannels.filter(ch => {
    if(searchQ && !ch.name.toLowerCase().includes(searchQ) && !(ch.country||'').toLowerCase().includes(searchQ) && !(COUNTRY_NAMES[ch.country]||'').toLowerCase().includes(searchQ)) return false;
    if(activeCat && !(ch.categories||[]).includes(activeCat)) return false;
    if(activeCountry && ch.country !== activeCountry) return false;
    return true;
  }).slice(0, 400);

  const countryLabel = activeCountry
    ? `${countryFlag(activeCountry)} ${COUNTRY_NAMES[activeCountry]||activeCountry}`
    : '';
  const sectionLabel = `📡 ${countryLabel ? countryLabel + ' · ' : ''}${filtered.length} channels${filtered.length===400?' (capped)':''}`;

  const iptvHtml = filtered.map(ch => pickItem(ch)).join('');

  list.innerHTML =
    (favHtml    ? `<div class="pick-section">⭐ Favourites</div>${favHtml}` : '') +
    (customHtml ? `<div class="pick-section">＋ Custom</div>${customHtml}` : '') +
    (iptvHtml   ? `<div class="pick-section">${sectionLabel}</div>${iptvHtml}` : '') +
    (!favHtml && !customHtml && !iptvHtml
      ? `<div style="padding:30px;text-align:center;color:var(--muted);font-size:11px">No channels found${activeCountry?' for this country':''}</div>`
      : '');
}

function pickItem(ch, isFav = false, isCustom = false){
  const flag = ch.flag || countryFlag(ch.country);
  const cat  = (ch.categories||[])[0] || '';
  const logo = ch.logo;
  const safeId = (ch.id||'').replace(/'/g,"\\'");
  return `<div class="pick-item${isFav?' fav':''}" onclick="assignChannel('${safeId}')">
    ${logo
      ? `<img class="pick-logo" src="${logo}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" loading="lazy"/><div class="pick-flag" style="display:none">${flag}</div>`
      : `<div class="pick-flag">${flag}</div>`}
    <div class="pick-body">
      <div class="pick-name">${isFav?'⭐ ':''}${ch.name||ch.id}</div>
      <div class="pick-meta">${flag} ${ch.country||''} ${cat?'· '+cat:''} ${ch.website?`· <a href="${ch.website}" target="_blank" onclick="event.stopPropagation()" style="color:var(--accent);text-decoration:none">↗</a>`:''}</div>
    </div>
  </div>`;
}

// ═══════════════════════════════════════════════════
// CUSTOM M3U
// ═══════════════════════════════════════════════════
function openM3U(){ document.getElementById('m3u-modal').classList.add('open'); }
function closeM3U(){ document.getElementById('m3u-modal').classList.remove('open'); }

async function addM3U(){
  const name = document.getElementById('m3u-name').value.trim() || 'Custom Stream';
  const url  = document.getElementById('m3u-url').value.trim();
  if(!url){ alert('Please enter a URL'); return; }

  if(url.endsWith('.m3u8') || url.includes('/playlist') || url.includes('/index') || url.includes('/live')){
    // Single stream URL
    const ch = { id: 'custom-'+Date.now(), name, country:'', flag:'📡', logo:null, urls:[url], categories:['custom'] };
    customChannels.unshift(ch);
  } else {
    // Try to fetch as M3U playlist
    try{
      const txt = await (await fetch(url)).text();
      const lines = txt.split('\n');
      let pending = null;
      lines.forEach(line => {
        line = line.trim();
        if(line.startsWith('#EXTINF')){
          const nameMatch = line.match(/,(.+)$/);
          const logoMatch = line.match(/tvg-logo="([^"]+)"/);
          const countryMatch = line.match(/tvg-country="([^"]+)"/);
          pending = {
            id: 'custom-'+Date.now()+'-'+Math.random(),
            name: nameMatch?.[1]?.trim() || 'Channel',
            logo: logoMatch?.[1] || null,
            country: countryMatch?.[1] || '',
            flag: countryMatch?.[1] ? countryFlag(countryMatch[1]) : '📡',
            categories: ['custom'],
            urls: [],
          };
        } else if(line && !line.startsWith('#') && pending){
          pending.urls.push(line);
          customChannels.push(pending);
          pending = null;
        }
      });
    } catch(e){
      alert('Could not fetch playlist. Try a direct .m3u8 stream URL instead.');
      return;
    }
  }

  document.getElementById('m3u-name').value = '';
  document.getElementById('m3u-url').value  = '';
  closeM3U();
  renderPicker();
  saveSession();
}

// ═══════════════════════════════════════════════════
// THEME
// ═══════════════════════════════════════════════════
let isLight = false;
function toggleTheme(){
  isLight = !isLight;
  document.body.classList.toggle('light', isLight);
  try{ localStorage.setItem('sw_theme', isLight ? 'light' : 'dark'); }catch{}
}

// ═══════════════════════════════════════════════════
// SESSION PERSISTENCE
// ═══════════════════════════════════════════════════
function saveSession(){
  try{
    const data = { layout, slots: slots.map(s => s ? {chId:s.chId, name:s.name, flag:s.flag, logo:s.logo} : null) };
    localStorage.setItem('sw_session', JSON.stringify(data));
  }catch{}
}

async function restoreSession(){
  try{
    const raw = localStorage.getItem('sw_session');
    if(!raw) return;
    const data = JSON.parse(raw);
    if(data.layout){
      layout = data.layout;
      const btn = document.querySelector(`.lbtn[onclick*="setLayout(${layout}"]`);
      document.querySelectorAll('.lbtn').forEach(b => b.classList.remove('on'));
      btn?.classList.add('on');
      while(slots.length < layout) slots.push(null);
      slots = slots.slice(0, layout);
      buildGrid();
    }
    if(data.slots){
      // Wait a beat for iptv-org channels to load
      await new Promise(r => setTimeout(r, 2000));
      data.slots.forEach((s, i) => {
        if(!s || i >= layout) return;
        const ch = FAVS.find(c => c.id === s.chId)
                || customChannels.find(c => c.id === s.chId)
                || allChannels.find(c => c.id === s.chId);
        if(ch){ activeSlot = i; assignChannel(s.chId); }
      });
    }
  }catch{}
}

// ═══════════════════════════════════════════════════
// BOOT
// ═══════════════════════════════════════════════════
// Restore theme
try{
  if(localStorage.getItem('sw_theme') === 'light'){ isLight = true; document.body.classList.add('light'); }
}catch{}

// Restore layout pref
try{
  const savedLayout = parseInt(localStorage.getItem('sw_layout'));
  if([1,2,4,6,9].includes(savedLayout)){
    layout = savedLayout;
    document.querySelectorAll('.lbtn').forEach(b => b.classList.remove('on'));
    document.querySelector(`.lbtn[onclick*="setLayout(${layout}"]`)?.classList.add('on');
  }
}catch{}

// Init slots array and build grid
while(slots.length < layout) slots.push(null);
buildGrid();

// Fetch channels then restore session
init().then(() => restoreSession());

// Close overlays on backdrop click
document.getElementById('m3u-modal').addEventListener('click', e => {
  if(e.target === document.getElementById('m3u-modal')) closeM3U();
});
document.getElementById('country-overlay').addEventListener('click', e => {
  if(e.target === document.getElementById('country-overlay')) closeCountryOverlay();
});
</script>


</body></html>