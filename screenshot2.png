<!DOCTYPE html>
<!-- saved from url=(0014)about:internet -->
<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Live TV Tower — Live TV Tower</title>
<script src="./screenshot2_files/hls.min.js.download"></script>
<style>
:root{
  --bg:#08090c;--surface:#0f1117;--surface2:#161820;--surface3:#1d1f28;
  --border:rgba(255,255,255,.07);--border2:rgba(255,255,255,.13);
  --text:#e4e6f0;--muted:#5a6080;
  --accent:#4f8fff;--accent2:#1a3a7a;--dim:rgba(79,143,255,.08);
  --live:#3ddc6e;--err:#e55;--amber:#d4a017;
  --font:system-ui,-apple-system,sans-serif;
  --mono:'JetBrains Mono','Fira Code',monospace;
}
body.light{
  --bg:#f2f4f8;--surface:#e8ebf2;--surface2:#dde0ea;--surface3:#d2d6e4;
  --border:rgba(0,0,0,.09);--border2:rgba(0,0,0,.16);
  --text:#1a1d2e;--muted:#6070a0;
  --accent:#1a5fff;--accent2:#c5d5ff;--dim:rgba(26,95,255,.07);
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:var(--font);font-size:13px}

/* ── TOPBAR ── */
.topbar{height:46px;display:flex;align-items:center;gap:10px;padding:0 14px;background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0;z-index:20}
.logo{display:flex;align-items:center;gap:8px;font-size:15px;font-weight:700;letter-spacing:-.03em;white-space:nowrap}
.logo-icon{font-size:18px}
.logo-sub{font-size:9px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;font-weight:400}
.topbar-mid{flex:1;display:flex;align-items:center;gap:6px}
.layout-btns{display:flex;gap:3px}
.lbtn{padding:3px 11px;border-radius:6px;border:1px solid var(--border2);background:transparent;color:var(--muted);font-size:10px;cursor:pointer;font-weight:600;transition:all .12s;white-space:nowrap}
.lbtn:hover{color:var(--text);border-color:var(--border2)}
.lbtn.on{border-color:var(--accent);color:var(--accent);background:var(--dim)}
.ch-count{font-size:10px;color:var(--muted);font-family:var(--mono);padding:0 8px;white-space:nowrap}
.topbar-right{display:flex;align-items:center;gap:6px}
.tbtn{padding:3px 10px;border-radius:6px;border:1px solid var(--border2);background:transparent;color:var(--muted);font-size:10px;cursor:pointer;transition:all .12s;white-space:nowrap}
.tbtn:hover{color:var(--text)}
.mute-btn{padding:3px 10px;border-radius:6px;border:1px solid var(--border2);background:transparent;color:var(--muted);font-size:11px;cursor:pointer}
.mute-btn.on{color:var(--live);border-color:var(--live)}

/* ── BODY LAYOUT ── */
.app-body{display:flex;height:calc(100vh - 46px);overflow:hidden}

/* ── SCREEN GRID ── */
.screens{flex:1;display:grid;gap:4px;padding:6px;background:var(--bg);min-width:0;min-height:0;overflow:hidden}
.screens.s1{grid-template-columns:1fr;grid-template-rows:1fr}
.screens.s2{grid-template-columns:repeat(2,1fr);grid-template-rows:1fr}
.screens.s4{grid-template-columns:repeat(2,1fr);grid-template-rows:repeat(2,1fr)}
.screens.s6{grid-template-columns:repeat(3,1fr);grid-template-rows:repeat(2,1fr)}
.screens.s9{grid-template-columns:repeat(3,1fr);grid-template-rows:repeat(3,1fr)}

/* ── SLOT ── */
.slot{background:var(--surface);border:2px solid var(--border);border-radius:8px;overflow:hidden;display:flex;flex-direction:column;cursor:pointer;transition:border-color .15s;position:relative}
.slot:hover{border-color:var(--border2)}
.slot.live{border-color:rgba(61,220,110,.3)}
.slot.focused{border-color:var(--accent);box-shadow:0 0 0 2px var(--accent2)}
.slot.active-pick{border-color:var(--accent);border-style:dashed}
.slot-hdr{display:flex;align-items:center;gap:5px;padding:4px 8px;background:var(--surface2);border-bottom:1px solid var(--border);flex-shrink:0;min-height:26px}
.slot-logo{width:16px;height:16px;border-radius:3px;object-fit:contain;flex-shrink:0}
.slot-name{flex:1;font-size:10px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--muted)}
.slot-name.live{color:var(--text)}
.slot-st{font-size:9px;font-family:var(--mono);flex-shrink:0}
.slot-st.live{color:var(--live)}.slot-st.loading{color:var(--amber)}.slot-st.err{color:var(--err)}
.slot-close{background:none;border:none;color:var(--muted);cursor:pointer;font-size:12px;padding:0 2px;line-height:1;flex-shrink:0;opacity:.6}
.slot-close:hover{color:var(--err);opacity:1}
.slot-fs{background:none;border:none;color:var(--muted);cursor:pointer;font-size:10px;padding:0 2px;line-height:1;flex-shrink:0;opacity:.5}
.slot-fs:hover{opacity:1;color:var(--text)}
.slot-sound{font-size:9px;color:var(--accent);font-family:var(--mono);flex-shrink:0;display:none}
.slot.focused .slot-sound{display:inline}
.active-badge{font-size:9px;color:var(--accent);font-family:var(--mono);flex-shrink:0}
.slot-vw{flex:1;position:relative;background:#000;min-height:0}
.slot-vw video{width:100%;height:100%;display:block;object-fit:contain;background:#000}
.slot-ph{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:var(--muted);pointer-events:none}
.slot-ph-icon{font-size:28px;opacity:.2}
.slot-ph-txt{font-size:10px;text-align:center;line-height:1.5;opacity:.7}
.slot-ph-hint{font-size:9px;color:var(--accent);opacity:.8;font-family:var(--mono)}

/* ── PICKER SIDEBAR ── */
.picker{width:270px;flex-shrink:0;border-left:1px solid var(--border);display:flex;flex-direction:column;background:var(--surface);overflow:hidden}
.picker-hdr{padding:8px;border-bottom:1px solid var(--border);flex-shrink:0}
.picker-search{display:flex;align-items:center;gap:6px;background:var(--surface2);border:1px solid var(--border2);border-radius:7px;padding:5px 9px;margin-bottom:7px}
.picker-search input{flex:1;background:none;border:none;outline:none;color:var(--text);font-size:11px}
.picker-search input::placeholder{color:var(--muted)}
.picker-search .si{color:var(--muted);font-size:12px;flex-shrink:0}
.cats{display:flex;gap:3px;flex-wrap:wrap}
.cat-btn{padding:2px 8px;border-radius:999px;border:1px solid var(--border);background:transparent;color:var(--muted);font-size:9px;cursor:pointer;white-space:nowrap;text-transform:capitalize;transition:all .1s}
.cat-btn:hover{border-color:var(--border2);color:var(--text)}
.cat-btn.on{border-color:var(--accent);color:var(--accent);background:var(--dim)}

/* ── COUNTRY OVERLAY ── */
.country-overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.6);backdrop-filter:blur(4px);align-items:center;justify-content:center}
.country-overlay.open{display:flex}
.country-modal{background:var(--surface);border:1px solid var(--border2);border-radius:14px;width:560px;max-width:95vw;max-height:80vh;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 24px 60px rgba(0,0,0,.5)}
.country-modal-hdr{padding:14px 16px 10px;border-bottom:1px solid var(--border);flex-shrink:0}
.country-modal-title{font-size:14px;font-weight:700;margin-bottom:8px;display:flex;align-items:center;gap:8px}
.country-modal-title span{font-size:18px}
.country-modal-sub{font-size:10px;color:var(--muted);margin-bottom:10px}
.country-search{display:flex;align-items:center;gap:7px;background:var(--surface2);border:1px solid var(--border2);border-radius:8px;padding:6px 10px}
.country-search input{flex:1;background:none;border:none;outline:none;color:var(--text);font-size:12px}
.country-search input::placeholder{color:var(--muted)}
.country-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:4px;padding:10px;overflow-y:auto;flex:1;min-height:0}
.country-grid::-webkit-scrollbar{width:3px}
.country-grid::-webkit-scrollbar-thumb{background:var(--border2)}
.country-card{display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:8px;border:1px solid var(--border);cursor:pointer;transition:all .1s;background:transparent}
.country-card:hover{background:var(--surface2);border-color:var(--border2)}
.country-card.active{background:var(--dim);border-color:var(--accent)}
.country-card-flag{font-size:18px;flex-shrink:0;line-height:1}
.country-card-body{min-width:0}
.country-card-name{font-size:11px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.country-card-count{font-size:9px;color:var(--muted);font-family:var(--mono)}
.country-modal-foot{padding:10px 16px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.country-active-pill{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--accent)}
.country-active-pill .cpill-clear{font-size:10px;color:var(--muted);cursor:pointer;padding:1px 6px;border:1px solid var(--border2);border-radius:999px;margin-left:4px}
.country-active-pill .cpill-clear:hover{color:var(--err);border-color:var(--err)}
.picker-list{flex:1;overflow-y:auto;min-height:0}
.picker-list::-webkit-scrollbar{width:3px}
.picker-list::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

/* ── SECTION HEADER in picker ── */
.pick-section{padding:5px 10px 3px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);background:var(--surface);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:2}

/* ── PICK ITEM ── */
.pick-item{display:flex;align-items:center;gap:8px;padding:6px 10px;cursor:pointer;border-bottom:1px solid var(--border);transition:background .08s}
.pick-item:hover{background:var(--surface2)}
.pick-item.fav{background:rgba(79,143,255,.04)}
.pick-item.fav:hover{background:rgba(79,143,255,.09)}
.pick-logo{width:24px;height:24px;border-radius:4px;object-fit:contain;background:var(--surface3);flex-shrink:0}
.pick-flag{width:24px;height:24px;border-radius:4px;background:var(--surface3);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}
.pick-body{flex:1;min-width:0}
.pick-name{font-size:11px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pick-meta{font-size:9px;color:var(--muted);margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pick-fav-star{font-size:10px;color:var(--accent);flex-shrink:0}

/* ── LOADING STATE ── */
.loading-overlay{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;background:var(--surface);z-index:10}
.spinner{width:28px;height:28px;border:2px solid var(--border2);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-txt{font-size:10px;color:var(--muted);font-family:var(--mono)}

/* ── CUSTOM M3U MODAL ── */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:100;align-items:center;justify-content:center}
.modal-bg.open{display:flex}
.modal{background:var(--surface);border:1px solid var(--border2);border-radius:12px;padding:20px;width:480px;max-width:95vw}
.modal h3{font-size:13px;font-weight:600;margin-bottom:4px}
.modal p{font-size:11px;color:var(--muted);margin-bottom:12px;line-height:1.6}
.modal input,.modal textarea{width:100%;background:var(--bg);border:1px solid var(--border2);border-radius:6px;padding:7px 10px;color:var(--text);font-size:11px;font-family:var(--mono);outline:none;margin-bottom:8px}
.modal input:focus,.modal textarea:focus{border-color:var(--accent)}
.modal textarea{height:80px;resize:vertical}
.modal-foot{display:flex;gap:6px;justify-content:flex-end}
.btn-cancel{background:transparent;border:1px solid var(--border2);color:var(--muted);padding:5px 12px;border-radius:6px;font-size:11px;cursor:pointer}
.btn-ok{background:var(--accent);color:#fff;border:none;padding:5px 14px;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer}
.btn-ok:hover{opacity:.88}

/* ── UTIL ── */
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.live-dot{width:5px;height:5px;background:var(--live);border-radius:50%;animation:blink 1.4s infinite;display:inline-block;margin-right:4px}
</style>
</head>
<body class="light">

<!-- TOPBAR -->
<div class="topbar">
  <div class="logo">
    <span class="logo-icon">📺</span>
    <div>
      <div>Live TV Tower</div>
      <div class="logo-sub">Live TV Tower</div>
    </div>
  </div>

  <div class="topbar-mid">
    <div class="layout-btns">
      <button class="lbtn" onclick="setLayout(1,this)">1</button>
      <button class="lbtn" onclick="setLayout(2,this)">2×1</button>
      <button class="lbtn on" onclick="setLayout(4,this)">2×2</button>
      <button class="lbtn" onclick="setLayout(6,this)">2×3</button>
      <button class="lbtn" onclick="setLayout(9,this)">3×3</button>
    </div>
    <span class="ch-count" id="ch-count"><span class="live-dot"></span>8,772 channels</span>
  </div>

  <div class="topbar-right">
    <button class="mute-btn" id="mute-btn" onclick="toggleMaster()" title="Master mute">🔇</button>
    <button class="tbtn" id="country-btn" onclick="openCountryOverlay()" title="Filter by country">🌍 Country</button>
    <button class="tbtn" onclick="clearAll()">✕ Clear all</button>
    <button class="tbtn" onclick="openM3U()">＋ M3U</button>
    <button class="tbtn" onclick="toggleTheme()">◑</button>
  </div>
</div>

<!-- BODY -->
<div class="app-body">

  <!-- SCREEN GRID -->
  <div class="screens s4" id="screens"><div class="slot live" id="slot-0">
      <div class="slot-hdr" id="slot-hdr-0"><img class="slot-logo" loading="lazy" src="./screenshot2_files/200px-Sky_News_International_logo_2016.svg.png" style="display: none;">
        
        <span class="slot-name live" id="slot-name-0">🇬🇧 Sky News</span>
        <span class="slot-sound">🔊</span>
        <span class="slot-st live" id="slot-st-0">● LIVE</span>
        
        
        
      <button class="slot-fs" title="Fullscreen">⛶</button><button class="slot-close" title="Remove">✕</button></div>
      <div class="slot-vw" id="slot-vw-0">
        <div class="slot-ph" id="slot-ph-0" style="display: none;">
          <div class="slot-ph-icon">👆</div>
          <div class="slot-ph-txt">Pick a channel →</div>
          <div class="slot-ph-hint">or double-click for fullscreen</div>
        </div>
      <video id="slot-vid-0" autoplay="" playsinline="" controls="" src="blob:https://namerami.github.io/d63d116f-5563-4cf9-b892-0583ca0ae2ba" style="display: block; width: 100%; height: 100%;"></video></div></div><div class="slot live" id="slot-1">
      <div class="slot-hdr" id="slot-hdr-1"><img class="slot-logo" loading="lazy" src="./screenshot2_files/200px-Euronews_2022_logo.svg.png" style="display: none;">
        
        <span class="slot-name live" id="slot-name-1">🇪🇺 Euronews</span>
        <span class="slot-sound">🔊</span>
        <span class="slot-st err" id="slot-st-1">✕ offline</span>
        
        
        
      <button class="slot-fs" title="Fullscreen">⛶</button><button class="slot-close" title="Remove">✕</button></div>
      <div class="slot-vw" id="slot-vw-1">
        <div class="slot-ph" id="slot-ph-1" style="display: flex;">
          <div class="slot-ph-icon">👆</div>
          <div class="slot-ph-txt">Pick a channel →</div>
          <div class="slot-ph-hint">or double-click for fullscreen</div>
        </div>
      <video id="slot-vid-1" autoplay="" playsinline="" controls="" src="blob:https://namerami.github.io/26f3bb7b-7251-4fe8-82b8-f471bbaf6fc7" style="display: none; width: 100%; height: 100%;"></video></div></div><div class="slot live focused" id="slot-2">
      <div class="slot-hdr" id="slot-hdr-2"><img class="slot-logo" loading="lazy" src="./screenshot2_files/200px-France_24_logo.svg.png" style="display: none;">
        
        <span class="slot-name live" id="slot-name-2">🇫🇷 France 24</span>
        <span class="slot-sound">🔊</span>
        <span class="slot-st live" id="slot-st-2">● LIVE</span>
        
        
        
      <button class="slot-fs" title="Fullscreen">⛶</button><button class="slot-close" title="Remove">✕</button></div>
      <div class="slot-vw" id="slot-vw-2">
        <div class="slot-ph" id="slot-ph-2" style="display: none;">
          <div class="slot-ph-icon">👆</div>
          <div class="slot-ph-txt">Pick a channel →</div>
          <div class="slot-ph-hint">or double-click for fullscreen</div>
        </div>
      <video id="slot-vid-2" autoplay="" playsinline="" controls="" src="blob:https://namerami.github.io/b751cb0e-d0e1-4ca8-8e6a-fd75b1fd1159" style="display: block; width: 100%; height: 100%;"></video></div></div><div class="slot live" id="slot-3">
      <div class="slot-hdr" id="slot-hdr-3"><img class="slot-logo" loading="lazy" src="./screenshot2_files/200px-DW_logo_2012.svg.png" style="display: none;">
        
        <span class="slot-name live" id="slot-name-3">🇩🇪 DW News</span>
        <span class="slot-sound">🔊</span>
        <span class="slot-st live" id="slot-st-3">● LIVE</span>
        
        
        
      <button class="slot-fs" title="Fullscreen">⛶</button><button class="slot-close" title="Remove">✕</button></div>
      <div class="slot-vw" id="slot-vw-3">
        <div class="slot-ph" id="slot-ph-3" style="display: none;">
          <div class="slot-ph-icon">👆</div>
          <div class="slot-ph-txt">Pick a channel →</div>
          <div class="slot-ph-hint">or double-click for fullscreen</div>
        </div>
      <video id="slot-vid-3" autoplay="" playsinline="" controls="" src="blob:https://namerami.github.io/d8707fca-21a1-48af-9bbf-f693a71fdf70" style="display: block; width: 100%; height: 100%;"></video></div></div></div>

  <!-- PICKER SIDEBAR -->
  <div class="picker">
    <div class="picker-hdr">
      <div class="picker-search">
        <span class="si">🔍</span>
        <input type="text" id="search" placeholder="Search channels, country…" oninput="onSearch(this.value)">
      </div>
      <div class="cats" id="cats"><button class="cat-btn on" onclick="setCat(&#39;all&#39;,this)">All</button><button class="cat-btn " onclick="setCat(&#39;animation&#39;,this)">animation</button><button class="cat-btn " onclick="setCat(&#39;auto&#39;,this)">auto</button><button class="cat-btn " onclick="setCat(&#39;business&#39;,this)">business</button><button class="cat-btn " onclick="setCat(&#39;classic&#39;,this)">classic</button><button class="cat-btn " onclick="setCat(&#39;comedy&#39;,this)">comedy</button><button class="cat-btn " onclick="setCat(&#39;cooking&#39;,this)">cooking</button><button class="cat-btn " onclick="setCat(&#39;culture&#39;,this)">culture</button><button class="cat-btn " onclick="setCat(&#39;documentary&#39;,this)">documentary</button><button class="cat-btn " onclick="setCat(&#39;education&#39;,this)">education</button><button class="cat-btn " onclick="setCat(&#39;entertainment&#39;,this)">entertainment</button><button class="cat-btn " onclick="setCat(&#39;family&#39;,this)">family</button><button class="cat-btn " onclick="setCat(&#39;general&#39;,this)">general</button><button class="cat-btn " onclick="setCat(&#39;kids&#39;,this)">kids</button><button class="cat-btn " onclick="setCat(&#39;legislative&#39;,this)">legislative</button><button class="cat-btn " onclick="setCat(&#39;lifestyle&#39;,this)">lifestyle</button><button class="cat-btn " onclick="setCat(&#39;movies&#39;,this)">movies</button><button class="cat-btn " onclick="setCat(&#39;music&#39;,this)">music</button><button class="cat-btn " onclick="setCat(&#39;news&#39;,this)">news</button><button class="cat-btn " onclick="setCat(&#39;outdoor&#39;,this)">outdoor</button><button class="cat-btn " onclick="setCat(&#39;public&#39;,this)">public</button><button class="cat-btn " onclick="setCat(&#39;relax&#39;,this)">relax</button><button class="cat-btn " onclick="setCat(&#39;religious&#39;,this)">religious</button><button class="cat-btn " onclick="setCat(&#39;science&#39;,this)">science</button><button class="cat-btn " onclick="setCat(&#39;series&#39;,this)">series</button><button class="cat-btn " onclick="setCat(&#39;shop&#39;,this)">shop</button><button class="cat-btn " onclick="setCat(&#39;sports&#39;,this)">sports</button><button class="cat-btn " onclick="setCat(&#39;travel&#39;,this)">travel</button><button class="cat-btn " onclick="setCat(&#39;weather&#39;,this)">weather</button></div>
    </div>
    <div class="picker-list" id="picker-list"><div class="pick-section">⭐ Favourites</div><div class="pick-item fav" onclick="assignChannel(&#39;SkyNews.gb&#39;)">
    <img class="pick-logo" src="./screenshot2_files/200px-Sky_News_International_logo_2016.svg.png" onerror="this.style.display=&#39;none&#39;;this.nextElementSibling.style.display=&#39;flex&#39;" loading="lazy" style="display: none;"><div class="pick-flag" style="display: flex;">🇬🇧</div>
    <div class="pick-body">
      <div class="pick-name">⭐ Sky News</div>
      <div class="pick-meta">🇬🇧 GB  </div>
    </div>
  </div><div class="pick-item fav" onclick="assignChannel(&#39;Euronews.int&#39;)">
